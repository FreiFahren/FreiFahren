# Local config for the Node/tsx tooling (seed CLI, drizzle-kit). Copy to .env. The worker, seed,
# and tests all use the Cloudflare D1 binding — there is no libsql / DATABASE_URL anymore. Tests get
# their bindings from vitest.config.ts; the local seed uses the wrangler D1 in .wrangler/state.

# Comma-separated list of frontend origins allowed to call the API.
CORS_ORIGINS=http://localhost:1871,http://127.0.0.1:1871

# Base URL of the telegram-worker; POST /reports forwards inspector reports to ${TELEGRAM_WORKER_URL}/report.
TELEGRAM_WORKER_URL=http://localhost:6010
REPORT_PASSWORD=password

# Cloudflare credentials for drizzle-kit's d1-http driver (db:studio) against the remote D1.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=

# Optional: when zone id + token are set, db:purge-cache purges the per-city transit Cache-Tag.
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
