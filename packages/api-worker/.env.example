# Local Bun/Node config (tests, seed, drizzle-kit). Copy to .env. On Cloudflare the worker uses the
# D1 binding instead; this libsql URL is only for Node runtimes (seed CLI, drizzle-kit, tests).

# libsql URL for the seed CLI / drizzle-kit (a local SQLite file).
DATABASE_URL=file:./local.db
# Tests default to file:./.test.db; only set this to override with another libsql URL.
DATABASE_URL_TEST=file:./.test.db

# Comma-separated list of frontend origins allowed to call the API.
CORS_ORIGINS=http://localhost:1871,http://127.0.0.1:1871

# Base URL of the telegram-worker; POST /reports forwards inspector reports to ${TELEGRAM_WORKER_URL}/report.
TELEGRAM_WORKER_URL=http://localhost:6010
REPORT_PASSWORD=password

# Optional: when both are set, db:purge-cache purges the `transit-network` tag from the edge cache.
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
