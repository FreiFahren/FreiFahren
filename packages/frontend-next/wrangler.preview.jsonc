{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "frontend-pr-preview",
  "compatibility_date": "2026-05-31",
  "main": "./worker/index.ts",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/relay/*"],
  },
  "workers_dev": true,
}
