{
  "extends": "expo/tsconfig.base",
  "include": [
    "App.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "app.config.js"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules/**",
    "node_modules/**/*",
    "node_modules/@maplibre/**/*",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js",
    "tsconfig.json"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "skipLibCheck": true
  }
}
